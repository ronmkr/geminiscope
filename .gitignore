# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if this is an executable, 
# but for TUIs it's often kept. I'll exclude it if you prefer, 
# but usually it's better to keep for reproducible builds.
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which aren't 
# needed for sharing project.
*.pdb

